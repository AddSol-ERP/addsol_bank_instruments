{
  "name": "BG Management Document",
  "module": "Addsol Bank Instruments",
  "app": "addsol_bank_instruments",
  "doctype": "DocType",
  "is_child_table": 1,
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "document_type",
      "fieldtype": "Select",
      "label": "Document Type",
      "options": "BG Application\nBG Approval Letter\nFD Certificate\nRenewal Letter\nClosure Letter\nClaim Letter\nOther",
      "in_list_view": 1,
      "reqd": 1
    },
    {
      "fieldname": "document_name",
      "fieldtype": "Data",
      "label": "Document Name",
      "in_list_view": 1
    },
    {
      "fieldname": "document_file",
      "fieldtype": "Attach",
      "label": "Attachment",
      "in_list_view": 1
    },
    {
      "fieldname": "upload_date",
      "fieldtype": "Date",
      "label": "Upload Date",
      "default": "Today"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    }
  ]
}