{
  "name": "BG Management Extension",
  "module": "Addsol Bank Instruments",
  "app": "addsol_bank_instruments",
  "doctype": "DocType",
  "is_child_table": 1,
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "extension_number",
      "fieldtype": "Int",
      "label": "Extension #",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "previous_expiry_date",
      "fieldtype": "Date",
      "label": "Previous Expiry Date",
      "in_list_view": 1,
      "reqd": 1
    },
    {
      "fieldname": "new_expiry_date",
      "fieldtype": "Date",
      "label": "New Expiry Date",
      "in_list_view": 1,
      "reqd": 1
    },
    {
      "fieldname": "extension_days",
      "fieldtype": "Int",
      "label": "Extension Days",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "extension_date",
      "fieldtype": "Date",
      "label": "Extension Date",
      "default": "Today",
      "reqd": 1
    },
    {
      "fieldname": "extension_charges",
      "fieldtype": "Currency",
      "label": "Extension Charges",
      "in_list_view": 1
    },
    {
      "fieldname": "approved_by",
      "fieldtype": "Link",
      "label": "Approved By",
      "options": "User"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    }
  ]
}